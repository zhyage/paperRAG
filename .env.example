# DeepSeek API key (required for LLM generation)
DEEPSEEK_API_KEY=sk-your-key-here

# Qdrant server
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=papers

# BGE-M3 embedding
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=32

# Chunking
CHUNK_MIN_SIZE=256
CHUNK_MAX_SIZE=1024
CHUNK_OVERLAP=128

# Retrieval
RETRIEVE_TOP_K=10
RERANK_TOP_K=5
ENABLE_RERANK=true

# LLM
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.3

# Marker parser
MARKER_FORCE_OCR=true
MARKER_USE_LLM=false

# Service
RAG_HOST=0.0.0.0
RAG_PORT=8765
MCP_SSE_PATH=/mcp/sse
